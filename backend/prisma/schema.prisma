datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Level {
  ASPIRANT
  EVEILLE
  ASCENDANT
  TRANSCENDANT
  SUPREME
  SACRE
  DIVIN
}

enum SpellCategory {
  OFFENSIVE
  DEFENSIVE
  UTILITY
}

type Section {
  title   String
  content String
}

type TableColumn {
  key   String // ex: "level", "spells", "features"
  label String // ex: "Niveau", "Sorts", "Compétences"
}

type TableCell {
  key   String
  value String
}

type TableRow {
  cells TableCell[]
}

type LevelTable {
  columns TableColumn[]
  rows    TableRow[]
}

model Class {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  slug        String     @unique
  name        String
  description String?
  table       LevelTable
  sections    Section[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subclasses Subclass[]
}

model Subclass {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  slug        String     @unique
  name        String
  description String?
  classId     String     @db.ObjectId
  table       LevelTable
  sections    Section[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  class Class @relation(fields: [classId], references: [id])

  @@unique([name, classId])
}

model Race {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String
  description String?
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Feat {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  slug         String    @unique
  name         String
  description  String?
  prerequisite String?
  sections     Section[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Spell {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  slug              String         @unique
  name              String
  description       String
  level             Level
  category          SpellCategory?
  prerequisiteSlugs String[]       @default([])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}
