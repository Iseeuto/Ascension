datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Level {
  ASPIRANT
  EVEILLE
  ASCENDANT
  TRANSCENDANT
  SUPREME
  SACRE
  DIVIN
}

type Section {
  title   String
  content String
}

model Class {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String
  description String?
  hitDice     Int?
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subclasses Subclass[]
}

model Subclass {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String
  description String?
  classId     String    @db.ObjectId
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class Class @relation(fields: [classId], references: [id])

  @@unique([name, classId])
}

model Race {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String
  description String?
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Feat {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  slug         String    @unique
  name         String
  description  String?
  prerequisite String?
  sections     Section[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Spell {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  description String
  level       Level
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
